generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  MANAGER
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

enum Department {
  Engineering
  Product
  Design
  Marketing
  Operations
  HR
  Other
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  role            Role
  department      Department
  experienceLevel ExperienceLevel
  teamName        String?
  bio             String?
  birthdate       String
  createdAt       DateTime        @default(now())
  tokens          RefreshToken[]
  addresses       Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  street1   String
  street2   String?
  city      String
  zipCode   Int
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
